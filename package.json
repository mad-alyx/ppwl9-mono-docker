{
  "name": "monorepo",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:frontend": "bun run --filter frontend dev",
    "dev:backend": "bun run --filter backend dev",
    "build": "bun run --filter '*' build",
    "start": "bun run --env-file=apps/backend/.env.production --filter '*' start"
  },
  "dependencies": {
    "@elysiajs/cookie": "^0.8.0",
    "@googleapis/classroom": "^11.1.0",
    "googleapis": "^171.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2"
  }
}